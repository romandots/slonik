{
  "name": "@slonk/mcp-kanban",
  "version": "1.3.0",
  "description": "MCP server bridging LLM agents to a Plane kanban board.",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.11 <23"
  },
  "packageManager": "pnpm@11.1.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.7.0",
    "fastify": "^5.8.5",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "yaml": "^2.6.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "eslint": "^9.16.0",
    "tsx": "^4.20.6",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.19.0",
    "vitest": "^4.1.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3"
    ]
  }
}
