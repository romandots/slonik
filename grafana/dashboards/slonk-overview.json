{
  "uid": "slonk-overview",
  "title": "slonk overview",
  "tags": ["slonk", "mcp"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "MCP tool calls / sec (by tool)",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (tool) (rate(mcp_tool_calls_total[1m]))",
          "legendFormat": "{{tool}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "MCP tool latency (p50/p95/p99)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, tool) (rate(mcp_tool_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{tool}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, tool) (rate(mcp_tool_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{tool}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, tool) (rate(mcp_tool_duration_seconds_bucket[5m])))",
          "legendFormat": "p99 {{tool}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "MCP errors (by tool / code)",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (tool, error_code) (rate(mcp_tool_calls_total{outcome=\"error\"}[5m]))",
          "legendFormat": "{{tool}} / {{error_code}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Plane API errors (by kind)",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (kind) (rate(mcp_plane_errors_total[5m]))",
          "legendFormat": "{{kind}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Rate-limit rejections / sec",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (scope, identity) (rate(mcp_rate_limited_total[5m]))",
          "legendFormat": "{{scope}} / {{identity}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "id": 6,
      "type": "logs",
      "title": "MCP error logs (Loki)",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service=\"mcp-kanban\"} |~ \"(?i)\\\"level\\\":\\\"(error|warn)\\\"\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    }
  ]
}
