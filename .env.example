# slonk — пример конфигурации
#
# Скопируйте этот файл в .env и замените ВСЕ значения, помеченные как (secret)
# или содержащие `change_me`, на свои. Полный референс переменных — в
# plane/docs/CONFIGURATION.md §2.
#
# Phase 1 заполнил Plane/Postgres/Valkey/RabbitMQ/MinIO-секции под реальные
# требования upstream Plane v1.3.0. MCP-секция дозаполняется в Phase 2+.

# =============================================================================
# Plane — общее
# =============================================================================
# Версия upstream-образов Plane (makeplane/plane-*:${PLANE_IMAGE_TAG}).
PLANE_IMAGE_TAG=v1.3.0

# Публичный URL, по которому пользователь обращается к Plane UI (через
# plane-proxy). Используется в исходящих письмах и в CORS_ALLOWED_ORIGINS.
PLANE_DOMAIN=http://localhost:3000
# Хост-порт, на котором публикуется plane-proxy (контейнер слушает :80).
PLANE_HOST_PORT=3000
# Домен для Caddy (внутри plane-proxy). `localhost` — без TLS, для прода
# подставьте FQDN, под который выписан сертификат.
PLANE_APP_DOMAIN=localhost
# Site-адрес для Caddy. `:80` — listen на все интерфейсы по 80 порту,
# без auto-TLS. Для прода замените на FQDN — Caddy сам выпустит сертификат
# (нужен CADDY_EMAIL).
PLANE_SITE_ADDRESS=:80

# (secret) Django SECRET_KEY для plane-backend. Сгенерировать один раз:
#   openssl rand -hex 32
PLANE_SECRET_KEY=change_me
# (secret) HMAC-секрет между plane-api и plane-live.
#   openssl rand -hex 32
PLANE_LIVE_SECRET_KEY=change_me

# Внутренний debug-режим Django (0/1). В проде = 0.
PLANE_DEBUG=0
# CORS-разрешённые origin'ы. По умолчанию — публичный домен Plane.
PLANE_CORS_ALLOWED_ORIGINS=http://localhost:3000

# Кол-во gunicorn-воркеров plane-api.
PLANE_GUNICORN_WORKERS=1
# Rate limit на API ключи. См. docs upstream Plane.
PLANE_API_KEY_RATE_LIMIT=60/minute
# Через сколько дней soft-deleted объекты вычищаются окончательно.
PLANE_HARD_DELETE_AFTER_DAYS=60
# Лимит размера upload'а (байт), default 5 MiB.
PLANE_FILE_SIZE_LIMIT=5242880
# TTL presigned URL'ов на скачивание/выгрузку (сек).
PLANE_SIGNED_URL_EXPIRATION=3600

# =============================================================================
# Plane — base URLs и пути (используется plane-api для генерации ссылок)
# =============================================================================
# В single-origin развёртывании (через plane-proxy) — все ссылки идут на
# один и тот же домен с разными path prefixes.
PLANE_APP_BASE_URL=http://localhost:3000
PLANE_APP_BASE_PATH=
PLANE_ADMIN_BASE_URL=http://localhost:3000
PLANE_ADMIN_BASE_PATH=/god-mode
PLANE_SPACE_BASE_URL=http://localhost:3000
PLANE_SPACE_BASE_PATH=/spaces
PLANE_LIVE_BASE_URL=http://localhost:3000
PLANE_LIVE_BASE_PATH=/live

# =============================================================================
# Plane — доступ MCP-сервера к Plane API (заполняется после bootstrap UI)
# =============================================================================
# Внутренний URL Plane API (mcp-kanban ↔ plane-api в internal_net).
PLANE_API_BASE_URL=http://plane-api:8000/api/v1
# (secret) — заполняется после bootstrap'а Plane UI (Settings → API Tokens).
# Скоуп: workspace-admin в `agents`.
PLANE_API_KEY=

# =============================================================================
# Postgres
# =============================================================================
POSTGRES_DB=plane
POSTGRES_USER=plane
# (secret)
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# =============================================================================
# Redis / Valkey
# =============================================================================
# Образ — valkey/valkey:7.x. Hostname в сети — `redis` (см. CONVENTIONS §6:
# именование по роли, кэш = redis).
REDIS_HOST=redis
REDIS_PORT=6379
# (secret) — опционально; valkey/valkey без пароля по умолчанию.
REDIS_PASSWORD=

# =============================================================================
# RabbitMQ
# =============================================================================
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_DEFAULT_USER=plane
# (secret)
RABBITMQ_DEFAULT_PASS=change_me
RABBITMQ_DEFAULT_VHOST=plane

# =============================================================================
# MinIO / S3
# =============================================================================
MINIO_ROOT_USER=plane
# (secret)
MINIO_ROOT_PASSWORD=change_me
# Бакеты создаются автоматически на старте plane-api (create_bucket).
MINIO_BUCKET_PLANE=plane-uploads
MINIO_BUCKET_MCP=mcp-artifacts
MINIO_REGION=us-east-1
# Включить bundled-MinIO (1) или внешний S3 (0).
MINIO_USE=1
# Endpoint внешнего S3 (если MINIO_USE=0). Для bundled оставьте пустым.
MINIO_ENDPOINT_SSL=0

# =============================================================================
# MCP Server (заполняется в Phase 2)
# =============================================================================
MCP_SERVER_PORT=8787
# (secret) — Bearer для агентов. Минимум 32 байта энтропии.
#   openssl rand -hex 32
# Bootstrap отказывается стартовать со значением change_me.
MCP_AUTH_TOKEN=change_me
MCP_DEFAULT_WORKSPACE=agents
# Проект адресуется по Plane-идентификатору (см. manifest.yaml: identifier).
# У Plane-проектов нет отдельного slug — это короткий код в ключах issue.
# Multi-project: перечисли identifier'ы через запятую в ALLOWED_PROJECTS,
# например `CODE_AGENTS,BACKEND,WEB`. Агент в каждом MCP-вызове передаёт
# `project: "<IDENTIFIER>"`; если параметр опущен — берётся DEFAULT_PROJECT.
# Подробнее: plane/docs/USER_GUIDE.md §2.2.
MCP_DEFAULT_PROJECT=SLONK
MCP_ALLOWED_PROJECTS=SLONK
MCP_AGENT_IDENTITY_MODE=per_user
MCP_OPTIONAL_WORKSPACES=false
MCP_LOG_LEVEL=info
# Опциональный файловый sink: /var/log/mcp/server.log
MCP_LOG_FILE=
MCP_RL_GLOBAL_RPS=20
MCP_RL_IDENTITY_RPS=5
MCP_ALLOW_CIDR=0.0.0.0/0
MCP_RETRY_ATTEMPTS=3
MCP_RETRY_BACKOFF_MS=200
MCP_PLANE_TIMEOUT_MS=10000
MCP_METRICS_ENABLED=false

# =============================================================================
# Caddy (опц., overlay docker-compose.proxy.yml) — внешний TLS-шлюз
# =============================================================================
# Поднимается через `make up-proxy` или
# `docker compose -f docker-compose.yml -f docker-compose.proxy.yml up -d`.
# С proxy overlay порты plane-proxy и mcp-kanban НЕ публикуются на хост —
# доступ только через Caddy (по domain'у) на :80/:443.
#
# TLS-режим: `internal` (default) — Caddy CA, self-signed; <email> —
# Let's Encrypt ACME (требует публичный DNS + порты 80/443 наружу).
CADDY_DOMAIN=plane.localhost
CADDY_MCP_DOMAIN=mcp.localhost
CADDY_TLS_MODE=internal
CADDY_ACME_EMAIL=
# Опц. — на каких портах хоста слушать Caddy (default 80/443):
# CADDY_HTTP_PORT=80
# CADDY_HTTPS_PORT=443

# =============================================================================
# Observability (опц., overlay docker-compose.obs.yml)
# =============================================================================
# Включается через `make up-obs`. Поднимает Prometheus / Grafana / Loki /
# Promtail. MCP-сервер начинает отдавать /metrics (MCP_METRICS_ENABLED=1
# проставляется overlay'ем).
GRAFANA_ADMIN_USER=admin
# (secret) — поменять перед первым запуском
GRAFANA_ADMIN_PASSWORD=change_me
GRAFANA_HOST_PORT=3001
PROMETHEUS_HOST_PORT=9090
PROMETHEUS_RETENTION=30d
LOKI_RETENTION=168h

# =============================================================================
# Backup (опц., overlay docker-compose.backup.yml)
# =============================================================================
# Включается через `make up-backup`. Сервис делает pg_dump + mc mirror MinIO +
# tar mcp_data раз в `BACKUP_CRON` (UTC) и складывает локально в volume
# `slonk_backup_data`. Файлы старше `BACKUP_RETENTION_DAYS` удаляются.
# Опц. внешний S3 destination: задайте все четыре BACKUP_S3_* — тогда бэкап
# дополнительно зальёт результат туда (mc cp / mc mirror).
BACKUP_CRON=0 3 * * *
BACKUP_RETENTION_DAYS=14
BACKUP_S3_ENDPOINT=
BACKUP_S3_BUCKET=
# (secret)
BACKUP_S3_ACCESS_KEY=
# (secret)
BACKUP_S3_SECRET_KEY=
