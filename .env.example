# slonk — пример конфигурации
#
# Скопируйте этот файл в .env и замените ВСЕ значения, помеченные как (secret)
# или содержащие `change_me`, на свои. Полный референс переменных — в
# plane/docs/CONFIGURATION.md §2.
#
# Phase 0 фиксирует структуру файла. Plane/Postgres/Redis/RabbitMQ/MinIO-секции
# дозаполняются в Phase 1, после стабилизации образов в docker-compose.yml.

# =============================================================================
# Plane (заполняется в Phase 1)
# =============================================================================
PLANE_DOMAIN=http://localhost:3000
PLANE_API_BASE_URL=http://plane-api:8000/api/v1
# (secret) — заполняется после bootstrap'а Plane UI (Settings → API Tokens).
PLANE_API_KEY=
# (secret) — Django SECRET_KEY, сгенерировать один раз
# (например: openssl rand -hex 32).
PLANE_SECRET_KEY=change_me
PLANE_DEBUG=false
PLANE_CORS_ALLOWED_ORIGINS=http://localhost:3000

# =============================================================================
# Postgres (заполняется в Phase 1)
# =============================================================================
POSTGRES_DB=plane
POSTGRES_USER=plane
# (secret)
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

# =============================================================================
# Redis / Valkey (заполняется в Phase 1)
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
# (secret) — опционально
REDIS_PASSWORD=

# =============================================================================
# RabbitMQ (заполняется в Phase 1)
# =============================================================================
RABBITMQ_HOST=rabbitmq
RABBITMQ_DEFAULT_USER=plane
# (secret)
RABBITMQ_DEFAULT_PASS=change_me
RABBITMQ_DEFAULT_VHOST=/

# =============================================================================
# MinIO (заполняется в Phase 1)
# =============================================================================
MINIO_ROOT_USER=plane
# (secret)
MINIO_ROOT_PASSWORD=change_me
MINIO_BUCKET_PLANE=plane
MINIO_BUCKET_MCP=mcp
MINIO_REGION=us-east-1

# =============================================================================
# MCP Server (заполняется в Phase 2)
# =============================================================================
MCP_SERVER_PORT=8787
# (secret) — Bearer для агентов. Минимум 32 байта энтропии
# (например: openssl rand -hex 32). Bootstrap отказывается стартовать со
# значением change_me.
MCP_AUTH_TOKEN=change_me
MCP_DEFAULT_WORKSPACE=agents
MCP_DEFAULT_PROJECT=code-agents
MCP_ALLOWED_PROJECTS=code-agents
MCP_AGENT_IDENTITY_MODE=per_user
MCP_OPTIONAL_WORKSPACES=false
MCP_LOG_LEVEL=info
# Опциональный файловый sink: /var/log/mcp/server.log
MCP_LOG_FILE=
MCP_RL_GLOBAL_RPS=20
MCP_RL_IDENTITY_RPS=5
MCP_ALLOW_CIDR=0.0.0.0/0
MCP_RETRY_ATTEMPTS=3
MCP_RETRY_BACKOFF_MS=200
MCP_PLANE_TIMEOUT_MS=10000
MCP_METRICS_ENABLED=false

# =============================================================================
# Caddy / TLS (опц., заполняется в Phase 7)
# =============================================================================
CADDY_DOMAIN=slonk.example.com
CADDY_MCP_DOMAIN=mcp.slonk.example.com
CADDY_ACME_EMAIL=

# =============================================================================
# Observability (опц., заполняется в Phase 8)
# =============================================================================
GRAFANA_ADMIN_USER=admin
# (secret)
GRAFANA_ADMIN_PASSWORD=change_me
PROMETHEUS_RETENTION=30d
LOKI_RETENTION=168h

# =============================================================================
# Backup (опц., заполняется в Phase 9)
# =============================================================================
BACKUP_CRON=0 3 * * *
BACKUP_RETENTION_DAYS=14
BACKUP_S3_ENDPOINT=
BACKUP_S3_BUCKET=
# (secret)
BACKUP_S3_ACCESS_KEY=
# (secret)
BACKUP_S3_SECRET_KEY=
